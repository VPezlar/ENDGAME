# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo

# Conda / virtual envs
.env
.venv
env/

# Fortran build artifacts
FDq/bin/FDq
FDq/obj/*.o
FDq/mod/*.mod

# Fortran runtime I/O (generated at run-time)
FDq/inputs/input_size.dat
FDq/output/d1.dat
FDq/output/d2.dat
FDq/output/eta.dat

# Simulation output data: per-run subdirectories (N{N}_q{q}_P{P}/)
# Keep timing.json files (small, useful for scaling analysis)
# Ignore the large eigenvector/eigenvalue data files
output/*/eigenvalues/
output/*/eigenvectors/
# Also cover the old flat output structure if it still exists
output/eigenvalues/*.txt
output/eigenvectors/*.csv

# Job log files (PBS and SLURM)
logs/*.log
*.log
triglobal_*.log
